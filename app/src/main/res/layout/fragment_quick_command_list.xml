<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/rc_background">

    <!-- 标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="常用指令管理"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_new_quick_command"
            style="@style/Widget.MaterialComponents.Button.Icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="新建"
            app:icon="@drawable/ic_add"
            app:iconGravity="textStart"
            app:backgroundTint="@color/rc_button_black"
            android:textColor="@color/rc_button_black_text" />

    </LinearLayout>

    <!-- 搜索栏 -->
    <androidx.appcompat.widget.SearchView
        android:id="@+id/search_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_search_view"
        android:queryHint="搜索指令名称或内容"
        app:iconifiedByDefault="false" />

    <!-- 空状态提示 -->
    <TextView
        android:id="@+id/tv_empty_state"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="暂无常用指令\n\n点击上方「新建」按钮创建您的第一个常用指令"
        android:textSize="16sp"
        android:textColor="@color/text_secondary"
        android:textAlignment="center"
        android:visibility="gone"
        android:drawableTop="@drawable/ic_terminal"
        android:drawablePadding="16dp"
        app:drawableTint="@color/text_tertiary" />

    <!-- 常用指令列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_quick_commands"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:padding="8dp"
        android:paddingBottom="16dp" />

</LinearLayout>
