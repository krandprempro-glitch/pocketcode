<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- 对话框标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="文件属性"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/primary_text"
            android:layout_marginBottom="16dp" />

        <!-- 文件图标和名称 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/file_icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="16dp"
                android:src="@drawable/ic_file"
                android:contentDescription="文件图标" />

            <TextView
                android:id="@+id/file_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="文件名"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/primary_text" />

        </LinearLayout>

        <!-- 文件详细信息 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 文件类型 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="类型："
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/file_type"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="文件"
                    android:textColor="@color/primary_text" />

            </LinearLayout>

            <!-- 文件路径 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="路径："
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/file_path"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="/path/to/file"
                    android:textColor="@color/primary_text" />

            </LinearLayout>

            <!-- 文件大小 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="大小："
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/file_size"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0 bytes"
                    android:textColor="@color/primary_text" />

            </LinearLayout>

            <!-- 修改时间 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="修改时间："
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/last_modified"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="未知"
                    android:textColor="@color/primary_text" />

            </LinearLayout>

            <!-- 权限 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="权限："
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/permissions"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="未知"
                    android:textColor="@color/primary_text" />

            </LinearLayout>

            <!-- 文件扩展名（仅文件）-->
            <LinearLayout
                android:id="@+id/file_extension_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/file_extension_label"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="扩展名："
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/file_extension"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="未知"
                    android:textColor="@color/primary_text" />

            </LinearLayout>

            <!-- MIME类型（仅文件）-->
            <LinearLayout
                android:id="@+id/file_mime_type_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/file_mime_type_label"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="MIME类型："
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/file_mime_type"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="未知"
                    android:textColor="@color/primary_text" />

            </LinearLayout>

        </LinearLayout>

        <!-- 操作按钮容器 -->
        <LinearLayout
            android:id="@+id/actions_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/download_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="下载"
                style="?attr/materialButtonOutlinedStyle" />

            <Button
                android:id="@+id/delete_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="删除"
                style="?attr/materialButtonOutlinedStyle" />

            <Button
                android:id="@+id/rename_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="重命名"
                style="?attr/materialButtonOutlinedStyle" />

            <Button
                android:id="@+id/bookmark_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="收藏"
                style="?attr/materialButtonOutlinedStyle" />

        </LinearLayout>

        <!-- 对话框按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/close_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="关闭"
                style="?attr/materialButtonStyle" />

            <Button
                android:id="@+id/cancel_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="取消"
                style="?attr/materialButtonOutlinedStyle" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>