<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:background="@drawable/claude_code_menu_background"
    android:elevation="8dp"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Claude Code 指令与快捷键"
            android:textColor="#ffffff"
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="12dp"
            android:gravity="center" />

        <!-- 分隔线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#444444"
            android:layout_marginHorizontal="8dp" />

        <!-- Claude Code 指令 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Claude Code 指令"
            android:textColor="#a0aec0"
            android:textSize="12sp"
            android:padding="8dp"
            android:paddingTop="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button
                android:id="@+id/cmd_help"
                style="@style/ClaudeCodeMenuButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="/help" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="获取帮助"
                android:textColor="#718096"
                android:textSize="11sp"
                android:layout_gravity="center_vertical"
                android:paddingStart="8dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button
                android:id="@+id/cmd_clear"
                style="@style/ClaudeCodeMenuButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="/clear" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="清屏"
                android:textColor="#718096"
                android:textSize="11sp"
                android:layout_gravity="center_vertical"
                android:paddingStart="8dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button
                android:id="@+id/cmd_compact"
                style="@style/ClaudeCodeMenuButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="/compact" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="紧凑模式"
                android:textColor="#718096"
                android:textSize="11sp"
                android:layout_gravity="center_vertical"
                android:paddingStart="8dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button
                android:id="@+id/cmd_add_on_dir"
                style="@style/ClaudeCodeMenuButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="/add-dir" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="添加目录"
                android:textColor="#718096"
                android:textSize="11sp"
                android:layout_gravity="center_vertical"
                android:paddingStart="8dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button
                android:id="@+id/cmd_shell"
                style="@style/ClaudeCodeMenuButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="/shell" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="执行shell命令"
                android:textColor="#718096"
                android:textSize="11sp"
                android:layout_gravity="center_vertical"
                android:paddingStart="8dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button
                android:id="@+id/cmd_edit"
                style="@style/ClaudeCodeMenuButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="/edit" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="编辑文件"
                android:textColor="#718096"
                android:textSize="11sp"
                android:layout_gravity="center_vertical"
                android:paddingStart="8dp" />
        </LinearLayout>

        <!-- 快捷键 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="快捷键"
            android:textColor="#a0aec0"
            android:textSize="12sp"
            android:padding="8dp"
            android:paddingTop="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Shift + Tab"
                android:textColor="#4a90e2"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/claude_code_shortcut_bg"
                android:padding="8dp"
                android:gravity="center" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="代码补全"
                android:textColor="#718096"
                android:textSize="11sp"
                android:layout_gravity="center_vertical"
                android:paddingStart="12dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Ctrl + L"
                android:textColor="#4a90e2"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/claude_code_shortcut_bg"
                android:padding="8dp"
                android:gravity="center" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="清屏"
                android:textColor="#718096"
                android:textSize="11sp"
                android:layout_gravity="center_vertical"
                android:paddingStart="12dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Ctrl + K"
                android:textColor="#4a90e2"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/claude_code_shortcut_bg"
                android:padding="8dp"
                android:gravity="center" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="打开文件搜索"
                android:textColor="#718096"
                android:textSize="11sp"
                android:layout_gravity="center_vertical"
                android:paddingStart="12dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Ctrl + Enter"
                android:textColor="#4a90e2"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/claude_code_shortcut_bg"
                android:padding="8dp"
                android:gravity="center" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="发送消息"
                android:textColor="#718096"
                android:textSize="11sp"
                android:layout_gravity="center_vertical"
                android:paddingStart="12dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Ctrl + /"
                android:textColor="#4a90e2"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/claude_code_shortcut_bg"
                android:padding="8dp"
                android:gravity="center" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="快捷键帮助"
                android:textColor="#718096"
                android:textSize="11sp"
                android:layout_gravity="center_vertical"
                android:paddingStart="12dp" />
        </LinearLayout>

    </LinearLayout>

</ScrollView>
