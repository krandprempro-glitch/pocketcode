<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/dark_background">

    <!-- Terminal View Container (hidden by default) -->
    <FrameLayout
        android:id="@+id/terminal_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="visible">
        
        <!-- Include the terminal layout -->
        <include layout="@layout/activity_termux" />
        
    </FrameLayout>

    <!-- Fragment Container (hidden by default) -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone" />

    <!-- Tab Layout at bottom -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/dark_tab_background"
        android:elevation="8dp"
        app:tabTextColor="@color/dark_tab_text"
        app:tabSelectedTextColor="@color/dark_tab_text_selected"
        app:tabIconTint="@color/tab_icon_color_selector"
        app:tabIndicatorColor="@color/dark_tab_indicator"
        app:tabIndicatorHeight="3dp"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabRippleColor="@color/dark_tab_ripple" />

</LinearLayout>