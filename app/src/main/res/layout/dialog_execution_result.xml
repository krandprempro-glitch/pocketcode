<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/rc_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- 结果状态 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="12dp"
                android:visibility="visible" />

            <ImageView
                android:id="@+id/iv_result_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="12dp"
                android:visibility="gone"
                android:src="@drawable/ic_check_circle" />

            <TextView
                android:id="@+id/tv_result_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="正在执行命令"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- 结果消息 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/rc_surface"
            app:strokeColor="@color/rc_card_stroke"
            app:strokeWidth="1dp">

            <TextView
                android:id="@+id/tv_result_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:text="请稍候，命令正在远程服务器上执行..."
                android:textSize="14sp"
                android:lineSpacingExtra="2dp" />

        </com.google.android.material.card.MaterialCardView>

        <!-- 命令输出 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/rc_surface"
            app:strokeColor="@color/rc_card_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="命令输出"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_command_output"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:background="@drawable/bg_code_block"
                    android:textColor="@color/rc_code_text"
                    android:padding="12dp"
                    android:textIsSelectable="true"
                    android:maxHeight="200dp"
                    android:scrollbars="vertical" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 按钮区域（横向滚动，防止换行） -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_gravity="center_horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_stop"
                    style="@style/AppButton.Danger"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginEnd="12dp"
                    android:text="停止" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_view_log"
                    style="@style/AppButton.Secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginEnd="12dp"
                    android:text="查看日志" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_re_execute"
                    style="@style/AppButton.Primary"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginEnd="12dp"
                    android:text="重新执行" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_close"
                    style="@style/AppButton.Secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="关闭" />

            </LinearLayout>
        </HorizontalScrollView>

    </LinearLayout>

</ScrollView>
