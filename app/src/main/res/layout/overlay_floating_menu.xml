<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/dialog_background">

    <TextView
        android:id="@+id/dialog_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="悬浮菜单"
        android:textStyle="bold"
        android:textSize="16sp"
        android:textColor="?attr/colorOnSurface"
        android:layout_marginBottom="12dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_color"/>

    <!-- SSH 连接（可折叠） -->
    <LinearLayout
        android:id="@+id/row_ssh"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_ssh"
            android:tint="?attr/colorOnSurface"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="SSH连接"
            android:textSize="15sp"
            android:textColor="?attr/colorOnSurface"/>

        <ImageView
            android:id="@+id/iv_ssh_expand"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_expand_more"
            android:tint="?attr/colorOnSurface"/>
    </LinearLayout>

    <!-- SSH配置列表（默认折叠） -->
    <LinearLayout
        android:id="@+id/container_ssh_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:background="?attr/colorSurfaceVariant">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_ssh_configs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="200dp"
            android:paddingStart="44dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"/>

        <!-- 空状态提示 -->
        <TextView
            android:id="@+id/tv_ssh_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="暂无SSH配置"
            android:textSize="13sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:paddingStart="44dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:visibility="gone"/>

        <!-- 管理连接按钮 -->
        <TextView
            android:id="@+id/tv_manage_ssh"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="管理连接..."
            android:textSize="14sp"
            android:textColor="?attr/colorPrimary"
            android:gravity="center_vertical"
            android:paddingStart="44dp"
            android:paddingEnd="8dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_color"/>

    <!-- 运行命令 -->
    <LinearLayout
        android:id="@+id/row_run"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_play_arrow"
            android:tint="?attr/colorOnSurface"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="运行命令"
            android:textSize="15sp"
            android:textColor="?attr/colorOnSurface"/>

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_chevron_right"
            android:tint="?attr/colorOnSurface"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_color"/>

    <!-- 快捷设置 -->
    <LinearLayout
        android:id="@+id/row_settings"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_settings"
            android:tint="?attr/colorOnSurface"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="快捷设置"
            android:textSize="15sp"
            android:textColor="?attr/colorOnSurface"/>

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_chevron_right"
            android:tint="?attr/colorOnSurface"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_color"/>

    <!-- 底部操作区：关闭按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/btn_close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="关闭"
            android:textColor="?attr/colorOnSurface"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"/>
    </LinearLayout>

</LinearLayout>
