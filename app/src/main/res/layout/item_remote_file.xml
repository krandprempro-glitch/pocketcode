<?xml version="1.0" encoding="utf-8"?>
<!-- 远程文件列表项布局 -->
<LinearLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingEnd="12dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:minHeight="64dp"
    android:gravity="center_vertical">

    <!-- 选择框 -->
    <CheckBox
        android:id="@+id/file_selection_checkbox"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginEnd="12dp"
        android:layout_gravity="center_vertical"
        android:visibility="gone" />

    <!-- 文件类型图标 -->
    <ImageView
        android:id="@+id/file_type_icon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="16dp"
        android:layout_gravity="center_vertical"
        android:src="@android:drawable/ic_menu_gallery"
        android:scaleType="centerInside" />

    <!-- 文件信息 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_gravity="center_vertical"
        android:orientation="vertical">

        <TextView
            android:id="@+id/file_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="#212121"
            android:textStyle="normal"
            android:singleLine="true"
            android:ellipsize="middle"
            android:text="文件名.txt" />

        <TextView
            android:id="@+id/file_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="13sp"
            android:textColor="#757575"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="1.2 KB · 2024-01-15 10:30" />
    </LinearLayout>

    <!-- 书签指示器 -->
    <ImageView
        android:id="@+id/bookmark_indicator"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:layout_marginEnd="8dp"
        android:layout_gravity="center_vertical"
        android:src="@android:drawable/btn_star"
        android:visibility="gone"
        app:tint="#FFD700" />
    
    <!-- 更多操作按钮 -->
    <ImageButton
        android:id="@+id/more_options_button"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="center_vertical"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_more"
        android:padding="8dp"
        android:tint="#757575"
        android:contentDescription="更多选项" />
</LinearLayout>
